global:
  resolve_timeout: 5m

route:
  group_by: ["alertname", "severity"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 1h
  receiver: "telegram"

receivers:
  - name: "telegram"
    telegram_configs:
      - bot_token: "REPLACE_WITH_YOUR_BOT_TOKEN"
        chat_id: 123456789  # REPLACE with your Telegram chat_id (integer)
        parse_mode: "HTML"
        message: |
          {{ range .Alerts }}
          <b>{{ .Labels.severity | toUpper }} — {{ .Labels.alertname }}</b>
          {{ .Annotations.summary }}
          {{ .Annotations.description }}
          Status: {{ .Status }}
          {{ end }}

inhibit_rules:
  - source_match:
      severity: "critical"
    target_match:
      severity: "warning"
    equal: ["alertname"]
